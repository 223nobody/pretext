pretext-reader-name = Pretext Reader
pretext-reader-open = 用 Pretext Reader 打开

# Preferences
prefs-title = Pretext Reader
prefs-defaultColumns = 默认栏数
prefs-defaultColumns-desc = 打开新文献时的文字栏数（1-4）。
prefs-defaultFontSize = 默认字号
prefs-defaultFontSize-desc = 字体大小，单位像素（12-28）。
prefs-defaultLineHeight = 默认行高
prefs-defaultLineHeight-desc = 行高倍率（1.2-2.2）。
prefs-defaultTheme = 默认主题
prefs-defaultTheme-desc = 打开新文献时应用的颜色主题。
prefs-bubbleRadius = 光标气泡半径
prefs-bubbleRadius-desc = 光标高亮气泡的大小，单位像素（0-150）。
prefs-openInWindow = 在独立窗口中打开
prefs-openInWindow-desc = 在单独窗口中打开阅读器，而非标签页。
prefs-localOnly = 仅本地处理
prefs-localOnly-desc = 所有文本在本地处理，不向任何服务器发送数据。
