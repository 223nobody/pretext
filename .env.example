# Pretext Reader deployment environment
#
# Baota panel quick start:
# 1. Copy this file to .env on the server.
# 2. Replace pretext.example.com with your real HTTPS domain.
# 3. Keep VITE_API_URL=/api/v1 when Baota reverse-proxies /api/ to the backend.

# Public site
PUBLIC_DOMAIN=pretext.example.com
PUBLIC_ORIGIN=https://pretext.example.com

# Backend
APP_NAME=Pretext Reader API
MAX_FILE_SIZE=52428800
CACHE_TTL=86400
ALLOWED_ORIGINS=https://pretext.example.com,http://pretext.example.com,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:3000,http://127.0.0.1:3000
MAX_TEXT_CHARS=1000000
MAX_PREVIEW_CHARS=500
CACHE_DIR=/app/cache
UPLOAD_DIR=/app/uploads
ENABLE_OCR=false
OCR_LANGUAGE=eng
URL_FETCH_USER_AGENT=PretextReader/0.1

# Frontend
VITE_API_URL=/api/v1
VITE_APP_NAME=Pretext Reader
VITE_DEFAULT_THEME=light

# Baota reverse proxy targets
FRONTEND_PORT=3000
BACKEND_PORT=8000
